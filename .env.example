# GNNcab - Environment Variables
# Copy to .env and fill in all values before starting the server.
# Never commit .env to version control.

# DATABASE
# PostgreSQL connection string
# Local dev: postgresql://gnncab:password@localhost:5432/gnncab
# DigitalOcean Managed DB: provided in the database dashboard
DATABASE_URL=postgresql://gnncab:STRONG_PASSWORD_HERE@localhost:5432/gnncab

# AUTHENTICATION
# MUST be changed in production - generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=24h

# SERVER
# Port the Express process listens on (Nginx proxies this to 80/443)
PORT=3000
NODE_ENV=production
# Deploy/install mode for setup/update validation: local or production
INSTALL_MODE=production

# CORS
# Comma-separated list of exact allowed browser origins - no wildcard, no trailing slashes
# Production: set only the exact frontend origin(s) you actually serve
# Local/dev: use explicit local origins such as http://localhost:5173
ALLOWED_ORIGINS=https://yourdomain.com

# ROUTING
# Which routing provider to use: 'mock' or 'osrm'
# Production must use 'osrm' explicitly.
# Use 'mock' only for intentional local/dev testing.
ROUTING_PROVIDER=osrm
# Base URL for the OSRM instance (required whenever ROUTING_PROVIDER=osrm)
OSRM_BASE_URL=http://localhost:5000

# DISPATCH TUNING
# Maximum number of sequential dispatch attempts before a trip is marked TIMEOUT
MAX_DISPATCH_ATTEMPTS=3
# Maximum eligible driver search radius in kilometres
MAX_DISPATCH_RADIUS_KM=10
# Near-tie window in kilometres within which zone preference may act as a tie-breaker
ZONE_TIEBREAK_THRESHOLD_KM=0.1

# PHASE 2 - NOTIFICATIONS (not yet implemented)
# SENDGRID_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# PHASE 2 - PAYMENTS (not yet implemented)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# PHASE 2 - CACHING / PUB-SUB (not yet required for single-instance)
# Redis connection string - required for multi-instance PM2 cluster mode.
# When absent, WebSocket broadcasts remain process-local (single-instance safe).
# REDIS_URL=redis://localhost:6379

